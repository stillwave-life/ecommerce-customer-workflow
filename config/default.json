{
  "skill_name": "ecommerce-customer-workflow",
  "version": "0.2.0",
  "description": "京东客服离线工作流 MVP",
  "platform": "jd",
  "default_data_sources": {
    "catalog": "shops/default/products.csv",
    "faq": "shops/default/faq.md",
    "rules": "shops/default/rules.md"
  },
  "supported_product_ref_types": ["sku", "product_id", "url"],
  "supported_source_types": ["text", "url", "image"],
  "storage_backend": "csv",
  "storage": {
    "csv": {
      "base_dir": "data/memory_store",
      "retention_days": 7
    },
    "postgres": {
      "host": "localhost",
      "port": 5432,
      "database": "ecommerce_customer_workflow",
      "user": "postgres",
      "password": "",
      "retention_days": 7,
      "enable_pgvector": false
    }
  },
  "features": {
    "structured_catalog": true,
    "knowledge_import": true,
    "customer_reply": true,
    "image_input": true,
    "jd_url_input": true,
    "browser_automation": false,
    "recommendation": false,
    "rag": true
  },
  "reply_policy": {
    "mode": "conservative",
    "forbid_unverified_stock_price_and_promises": true
  }
}
